{
    "name": "chuckbartowski/plesk-sdk",
    "description": "PHP SDK for the Plesk REST API (v2) with typed clients, high-level modules and a CLI bridge",
    "type": "library",
    "license": "MIT",
    "keywords": ["plesk", "api", "sdk", "rest", "hosting", "php"],
    "authors": [
        {
            "name": "Chuck Bartowski"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/http-client": "^6.4|^7.0",
        "symfony/http-client-contracts": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "symfony/config": "^6.4|^7.0",
        "symfony/dependency-injection": "^6.4|^7.0",
        "symfony/http-kernel": "^6.4|^7.0"
    },
    "suggest": {
        "symfony/http-kernel": "To register PleskSdkBundle in a Symfony application",
        "symfony/config": "To register PleskSdkBundle in a Symfony application",
        "symfony/dependency-injection": "To register PleskSdkBundle in a Symfony application"
    },
    "autoload": {
        "psr-4": {
            "ChuckBartowski\\PleskSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChuckBartowski\\PleskSdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
